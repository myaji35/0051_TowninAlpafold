# TowninGraph MVP 환경변수 예시
# 사용법: 이 파일을 복사하여 .env 로 만들고 실제 키 값을 채울 것
# cp .env.example .env

# ─────────────────────────────────────
# 카카오 로컬 API
# 발급: https://developers.kakao.com/
# 한도: 일 30만 호출 (무료)
# ─────────────────────────────────────
KAKAO_REST_API_KEY=

# ─────────────────────────────────────
# SGIS Plus API (통계청)
# 발급: https://sgis.kostat.go.kr/developer/
# 한도: 일 5,000회 (무료)
# ─────────────────────────────────────
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=
